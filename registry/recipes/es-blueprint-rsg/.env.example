# Required NVIDIA-hosted inference credential.
NVIDIA_API_KEY=

# Token used by the containerized Jupyter workspace.
JUPYTER_TOKEN=nvidia-ai-hub

# Optional model override used by the notebook.
LLM_MODEL=meta/llama-3.1-70b-instruct

# VIAVI AI RSG connection settings used by the upstream PoC.
RSG_HOST=3.211.96.252
RSG_USER_NAME=user1
SCENARIO_CONF=ai_rsg_config/config.conf
RSG_ADDRESS=
RSG_WHEEL_ADDRESS=http://3.211.96.252:8000

# Notes:
# - Access to VIAVI AI RSG and the ADK wheel requires VIAVI authorization.
# - The upstream notebook expects data/UEReports.csv and data/CellReports.csv.
# - This recipe is a research notebook workflow, not a production web service.
