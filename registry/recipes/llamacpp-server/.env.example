LLAMA_CPP_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
LLAMA_CPP_PORT=3096
LLAMA_SERVER_HOST=0.0.0.0
LLAMA_SERVER_INTERNAL_PORT=8080
LLAMA_MODEL_ALIAS=gemma-3-1b-it-q4-k-m
LLAMA_ARG_HF_REPO=ggml-org/gemma-3-1b-it-GGUF:Q4_K_M
LLAMA_ARG_MODEL=
HF_TOKEN=
LLAMA_API_KEY=
LLAMA_ARG_CTX_SIZE=8192
LLAMA_ARG_N_PARALLEL=2
LLAMA_ARG_N_GPU_LAYERS=999
LLAMA_ARG_ENDPOINT_METRICS=1
LLAMA_ARG_ENDPOINT_SLOTS=1
LLAMA_ARG_CACHE_PROMPT=1
LLAMA_ARG_CONT_BATCHING=1
LLAMA_ARG_JINJA=1
LLAMA_ARG_THREADS_HTTP=4
LLAMA_ARG_TIMEOUT=600
LLAMA_SLOT_SAVE_PATH=/slots
LLAMA_SLEEP_IDLE_SECONDS=-1
