# Copy to .env and adapt for your Jan host deployment.
# Jan requires a non-empty API key for its Local API Server.

JAN_SERVER_PORT=1337
JAN_MODEL_ID=janhq/Jan-v3-4B-base-instruct-gguf
JAN_CONTEXT_LENGTH=32768
JAN_API_KEY=change-me
JAN_SERVER_HOST=127.0.0.1
JAN_API_PREFIX=/v1
JAN_CORS_ENABLED=true
JAN_TRUSTED_HOSTS=
JAN_VERBOSE_LOGS=true
