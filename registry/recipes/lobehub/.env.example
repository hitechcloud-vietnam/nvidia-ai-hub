LOBEHUB_HOST_PORT=3210
LOBEHUB_IMAGE=lobehub/lobehub:latest
POSTGRES_IMAGE=pgvector/pgvector:pg16
REDIS_IMAGE=redis:7-alpine
RUSTFS_IMAGE=rustfs/rustfs:latest
POSTGRES_DB=lobehub
POSTGRES_USER=lobehub
POSTGRES_PASSWORD=change-me-lobehub-postgres
REDIS_PASSWORD=change-me-lobehub-redis
APP_URL=http://localhost:3210
KEY_VAULTS_SECRET=change-me-lobehub-key-vault-secret
DATABASE_URL=postgresql://lobehub:change-me-lobehub-postgres@postgres:5432/lobehub
REDIS_URL=redis://:change-me-lobehub-redis@redis:6379/0
S3_ENDPOINT=http://rustfs:9000
S3_BUCKET=lobehub
S3_ACCESS_KEY=lobehub
S3_SECRET_KEY=change-me-lobehub-s3-secret
S3_PUBLIC_DOMAIN=http://localhost:9000
RUSTFS_CONSOLE_PORT=9001
