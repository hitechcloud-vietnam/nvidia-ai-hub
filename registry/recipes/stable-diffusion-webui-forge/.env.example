# Stable Diffusion WebUI Forge runtime configuration
# Forge reads COMMANDLINE_ARGS from the environment at startup.

COMMANDLINE_ARGS=--listen --port 7860 --data-dir /data
HF_HOME=/data/.huggingface
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu121
PYTORCH_CUDA_ALLOC_CONF=backend:cudaMallocAsync
GRADIO_ANALYTICS_ENABLED=False

# Optional examples:
# COMMANDLINE_ARGS=--listen --port 7860 --data-dir /data --api
# COMMANDLINE_ARGS=--listen --port 7860 --data-dir /data --ckpt-dir /data/models/Stable-diffusion --lora-dir /data/models/Lora --embeddings-dir /data/embeddings
