server {
    listen 80;
    server_name _;
    client_max_body_size 20m;

    resolver 127.0.0.11 ipv6=off;

    location = /healthz {
        access_log off;
        add_header Content-Type text/plain;
        return 200 'ok';
    }

    location /v1/ {
        proxy_pass ${OPENROUTER_UPSTREAM_SCHEME}://${OPENROUTER_UPSTREAM_HOST}/api/;
        proxy_http_version 1.1;
        proxy_set_header Host ${OPENROUTER_UPSTREAM_HOST};
        proxy_set_header Connection "";
        proxy_set_header Authorization $http_authorization;
        proxy_set_header Content-Type $content_type;
        proxy_set_header HTTP-Referer $http_http_referer;
        proxy_set_header X-Title $http_x_title;
        proxy_set_header X-OpenRouter-Title $http_x_openrouter_title;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering off;
    }
}
