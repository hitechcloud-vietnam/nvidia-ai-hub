# Copy to .env and adapt for your OpenRouter tenant.
# This recipe starts a lightweight local relay shim that forwards `/v1/*` requests to the hosted OpenRouter API.

OPENROUTER_API_KEY=change-me
OPENROUTER_DEFAULT_MODEL=openrouter/auto
OPENROUTER_HTTP_REFERER=https://your-company.example
OPENROUTER_APP_TITLE=NVIDIA AI Hub
OPENROUTER_CATEGORIES=
OPENROUTER_ROUTE=auto
OPENROUTER_PROVIDER=
OPENROUTER_RELAY_PORT=3015
OPENROUTER_UPSTREAM_SCHEME=https
OPENROUTER_UPSTREAM_HOST=openrouter.ai
