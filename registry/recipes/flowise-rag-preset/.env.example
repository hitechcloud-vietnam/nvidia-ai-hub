HOST_PORT=3089
FLOWISE_IMAGE=flowiseai/flowise:latest
PORT=3000
FLOWISE_FILE_SIZE_LIMIT=200mb
DEBUG=false
LOG_LEVEL=info
DATABASE_TYPE=sqlite
DATABASE_PATH=/root/.flowise
LOG_PATH=/root/.flowise/logs
SECRETKEY_PATH=/root/.flowise
BLOB_STORAGE_PATH=/root/.flowise/storage
FLOWISE_SECRETKEY_OVERWRITE=replace-with-a-long-random-encryption-key
TOKEN_HASH_SECRET=replace-with-a-long-random-token-hash-secret
EXPRESS_SESSION_SECRET=replace-with-a-long-random-session-secret
JWT_AUTH_TOKEN_SECRET=replace-with-a-long-random-jwt-auth-secret
JWT_REFRESH_TOKEN_SECRET=replace-with-a-long-random-jwt-refresh-secret
JWT_ISSUER=flowise-rag-preset
JWT_AUDIENCE=flowise-rag-preset
DISABLE_FLOWISE_TELEMETRY=true
SHOW_COMMUNITY_NODES=false
OLLAMA_BASE_URL=http://host.docker.internal:11435
MODEL_LIST_CONFIG_JSON=
CORS_ORIGINS=
IFRAME_ORIGINS=
TOOL_FUNCTION_BUILTIN_DEP=
TOOL_FUNCTION_EXTERNAL_DEP=
ALLOW_BUILTIN_DEP=false