HOST_PORT=3090
LANGFLOW_IMAGE=langflowai/langflow:latest
LANGFLOW_HOST=0.0.0.0
LANGFLOW_PORT=7860
LANGFLOW_CONFIG_DIR=/app/langflow
LANGFLOW_AUTO_LOGIN=false
LANGFLOW_SAVE_DB_IN_CONFIG_DIR=true
LANGFLOW_SECRET_KEY=replace-with-a-long-random-secret-key
LANGFLOW_SUPERUSER=langflow-admin
LANGFLOW_SUPERUSER_PASSWORD=replace-with-a-long-random-admin-password
LANGFLOW_API_KEY_SOURCE=env
LANGFLOW_API_KEY=replace-with-a-long-random-api-key
LANGFLOW_OPEN_BROWSER=false
LANGFLOW_LOG_LEVEL=info
LANGFLOW_LOG_FILE=logs/langflow.log
LANGFLOW_WORKERS=1
LANGFLOW_WORKER_TIMEOUT=60000
LANGFLOW_MAX_FILE_SIZE_UPLOAD=10000
LANGFLOW_STORE_ENVIRONMENT_VARIABLES=true
LANGFLOW_FALLBACK_TO_ENV_VAR=true
LANGFLOW_REMOVE_API_KEYS=false
LANGFLOW_BACKEND_ONLY=false
DO_NOT_TRACK=true
OLLAMA_BASE_URL=http://host.docker.internal:11435
OPENAI_API_BASE=http://host.docker.internal:11435/v1
OPENAI_API_KEY=ollama