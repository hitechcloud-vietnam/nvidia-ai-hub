# Network ports exposed on the DGX Spark host.
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432
MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091

# Database and object store credentials.
POSTGRES_DB=chatbot
POSTGRES_USER=chatbot_user
POSTGRES_PASSWORD=
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=

# Backend-visible supervisor model list.
CHATBOT_MODELS=gpt-oss-120b

# Vision model served through TensorRT-LLM.
QWEN_VL_MODEL_ID=Qwen/Qwen2-VL-7B-Instruct
QWEN_VL_GPU_DEVICE=0

# GGUF download locations for llama.cpp-backed services.
DEEPSEEK_CODER_URL=https://huggingface.co/TheBloke/deepseek-coder-6.7B-instruct-GGUF/resolve/main/deepseek-coder-6.7b-instruct.Q8_0.gguf
QWEN_EMBEDDING_URL=https://huggingface.co/Qwen/Qwen3-Embedding-4B-GGUF/resolve/main/Qwen3-Embedding-4B-Q8_0.gguf
GPT_OSS_PART_1_URL=https://huggingface.co/ggml-org/gpt-oss-120b-GGUF/resolve/main/gpt-oss-120b-mxfp4-00001-of-00003.gguf
GPT_OSS_PART_2_URL=https://huggingface.co/ggml-org/gpt-oss-120b-GGUF/resolve/main/gpt-oss-120b-mxfp4-00002-of-00003.gguf
GPT_OSS_PART_3_URL=https://huggingface.co/ggml-org/gpt-oss-120b-GGUF/resolve/main/gpt-oss-120b-mxfp4-00003-of-00003.gguf

# Optional smaller supervisor download if you decide to swap away from gpt-oss-120b in docker-compose.yml.
GPT_OSS_20B_URL=https://huggingface.co/ggml-org/gpt-oss-20b-GGUF/resolve/main/gpt-oss-20b-mxfp4.gguf
