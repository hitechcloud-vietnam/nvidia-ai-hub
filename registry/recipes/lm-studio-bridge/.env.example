# Copy to .env and adapt for your LM Studio host deployment.

LM_STUDIO_PORT=1234
LM_STUDIO_MODEL=openai/gpt-oss-20b
LM_STUDIO_MODEL_ALIAS=nvidia-ai-hub-lm-studio
LM_STUDIO_GPU_OFFLOAD=max
LM_STUDIO_CONTEXT_LENGTH=8192
LM_STUDIO_ENABLE_CORS=false
LM_STUDIO_API_KEY=
LM_STUDIO_SERVE_ON_LAN=false
LM_STUDIO_JIT_MODEL_LOADING=true
