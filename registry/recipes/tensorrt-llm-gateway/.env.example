TRTLLM_IMAGE=nvcr.io/nvidia/tensorrt-llm/release:spark-single-gpu-dev
TRTLLM_PORT=3098
TRTLLM_INTERNAL_PORT=8000
TRTLLM_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
TRTLLM_TOKENIZER=
TRTLLM_BACKEND=pytorch
TRTLLM_HOST=0.0.0.0
TRTLLM_LOG_LEVEL=info
TRTLLM_TP_SIZE=1
TRTLLM_PP_SIZE=1
TRTLLM_EP_SIZE=1
TRTLLM_MAX_BATCH_SIZE=
TRTLLM_MAX_NUM_TOKENS=
TRTLLM_MAX_SEQ_LEN=
TRTLLM_KV_CACHE_FREE_GPU_MEMORY_FRACTION=
TRTLLM_NUM_POSTPROCESS_WORKERS=
TRTLLM_TRUST_REMOTE_CODE=false
TRTLLM_REASONING_PARSER=
TRTLLM_ENABLE_ITER_PERF_STATS=true
TRTLLM_SHM_SIZE=16g
HF_TOKEN=
TRTLLM_NO_USAGE_STATS=1