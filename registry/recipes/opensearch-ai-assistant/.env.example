HOST_PORT=3091
OPENSEARCH_API_PORT=9201
OPENSEARCH_TRANSPORT_PORT=9301
OPENSEARCH_IMAGE=opensearchproject/opensearch:3.4.0
OPENSEARCH_DASHBOARDS_IMAGE=opensearchproject/opensearch-dashboards:3.4.0
OPENSEARCH_INITIAL_ADMIN_PASSWORD=replace-with-a-strong-admin-password
OPENSEARCH_JAVA_OPTS=-Xms2g -Xmx2g
DASHBOARDS_USERNAME=admin
DASHBOARDS_PASSWORD=replace-with-the-same-admin-password
DISABLE_SECURITY_DASHBOARDS_PLUGIN=false
OLLAMA_BASE_URL=http://host.docker.internal:11435
QUERY_ASSIST_AGENT_CONFIG=os_query_assist_ppl
QUERY_ASSIST_TIME_RANGE_AGENT_CONFIG=os_query_time_range_parser
