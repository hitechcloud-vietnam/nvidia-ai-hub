LANGFUSE_HOST_PORT=3001
LANGFUSE_IMAGE=langfuse/langfuse:latest
POSTGRES_IMAGE=postgres:16-alpine
CLICKHOUSE_IMAGE=clickhouse/clickhouse-server:24.12
REDIS_IMAGE=redis:7-alpine
MINIO_IMAGE=minio/minio:RELEASE.2025-02-18T16-25-55Z

POSTGRES_DB=langfuse
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=change-me-langfuse-postgres

CLICKHOUSE_DB=langfuse
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change-me-langfuse-clickhouse

REDIS_PASSWORD=change-me-langfuse-redis

MINIO_ROOT_USER=langfuse
MINIO_ROOT_PASSWORD=change-me-langfuse-minio
MINIO_BUCKET=langfuse
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change-me-langfuse-nextauth-secret
SALT=change-me-langfuse-salt
LANGFUSE_INIT_ORG_ID=
LANGFUSE_INIT_ORG_NAME=
LANGFUSE_INIT_PROJECT_ID=
LANGFUSE_INIT_PROJECT_NAME=
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
TELEMETRY_ENABLED=false
