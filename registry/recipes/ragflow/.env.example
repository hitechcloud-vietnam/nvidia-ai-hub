# RAGFlow core
DOC_ENGINE=elasticsearch
DEVICE=cpu
RAGFLOW_IMAGE=infiniflow/ragflow:v0.24.0
API_PROXY_SCHEME=python
RAGFLOW_HOST=0.0.0.0
TZ=UTC
REGISTER_ENABLED=1
USE_DOCLING=false
MEM_LIMIT=6442450944

# Web and API ports
SVR_WEB_HTTP_PORT=3082
SVR_HTTP_PORT=9386
ADMIN_SVR_HTTP_PORT=9387

# Elasticsearch
STACK_VERSION=8.11.3
ES_HOST=es01
ES_PORT=1202
ELASTIC_PASSWORD=change-this-elastic-password

# MySQL
MYSQL_HOST=mysql
MYSQL_DBNAME=rag_flow
MYSQL_USER=root
MYSQL_PASSWORD=change-this-mysql-password
MYSQL_PORT=3306
EXPOSE_MYSQL_PORT=5456
MYSQL_MAX_PACKET=1073741824

# MinIO
MINIO_HOST=minio
MINIO_PORT=9002
MINIO_CONSOLE_PORT=9003
MINIO_USER=rag_flow
MINIO_PASSWORD=change-this-minio-password
MINIO_BUCKET=
MINIO_PREFIX_PATH=
MINIO_SECURE=false
MINIO_VERIFY=true

# Redis
REDIS_HOST=redis
REDIS_PORT=6381
REDIS_PASSWORD=change-this-redis-password
REDIS_USERNAME=

# Optional upload sizing
# MAX_CONTENT_LENGTH=1073741824
# DOC_BULK_SIZE=4
# EMBEDDING_BATCH_SIZE=16

# Optional mirror if Hugging Face is restricted
# HF_ENDPOINT=https://hf-mirror.com
