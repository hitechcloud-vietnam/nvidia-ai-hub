# Build-time sandbox defaults. Adjust these before the first build if you want
# a different model, provider, or chat URL baked into the image.
NEMOCLAW_MODEL=nvidia/nemotron-3-super-120b-a12b
NEMOCLAW_PROVIDER_KEY=nvidia
NEMOCLAW_PRIMARY_MODEL_REF=nvidia/nemotron-3-super-120b-a12b
CHAT_UI_URL=http://127.0.0.1:18790
NEMOCLAW_INFERENCE_BASE_URL=https://integrate.api.nvidia.com/v1
NEMOCLAW_INFERENCE_API=openai-completions
NEMOCLAW_INFERENCE_COMPAT_B64=e30=
NEMOCLAW_WEB_CONFIG_B64=e30=
NEMOCLAW_MESSAGING_CHANNELS_B64=W10=
NEMOCLAW_MESSAGING_ALLOWED_IDS_B64=e30=
NEMOCLAW_DISCORD_GUILDS_B64=e30=
NEMOCLAW_BUILD_ID=spark-ai-hub

# Set to 1 for local/headless bootstrap builds that skip device-pairing auth.
NEMOCLAW_DISABLE_DEVICE_AUTH=1

# Optional runtime credential for the default NVIDIA-hosted inference flow.
NVIDIA_API_KEY=

# Writable NemoClaw state is persisted under `registry/recipes/nemoclaw/data/`.
# After the first launch, the dashboard token is exported to:
#   registry/recipes/nemoclaw/data/metadata/openclaw-token.txt