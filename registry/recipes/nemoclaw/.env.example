# Build-time sandbox defaults for the DGX Spark local-Ollama profile.
# Adjust these before the first build if you want a different model or route.
NEMOCLAW_MODEL=nemotron-3-super:120b
NEMOCLAW_PROVIDER_KEY=inference
NEMOCLAW_PRIMARY_MODEL_REF=inference/nemotron-3-super:120b
CHAT_UI_URL=http://127.0.0.1:18790
NEMOCLAW_INFERENCE_BASE_URL=http://host.openshell.internal:11434/v1
NEMOCLAW_INFERENCE_API=openai-completions
NEMOCLAW_INFERENCE_COMPAT_B64=e30=
NEMOCLAW_WEB_CONFIG_B64=e30=
# Default telegram channel wiring baked into the image: ["telegram"]
NEMOCLAW_MESSAGING_CHANNELS_B64=WyJ0ZWxlZ3JhbSJd
# Optional base64-encoded JSON map such as {"telegram":["123456789"]}
NEMOCLAW_MESSAGING_ALLOWED_IDS_B64=e30=
NEMOCLAW_DISCORD_GUILDS_B64=e30=
NEMOCLAW_BUILD_ID=spark-ai-hub

# Set to 1 for local/headless bootstrap builds that skip device-pairing auth.
NEMOCLAW_DISABLE_DEVICE_AUTH=1

# Optional runtime credential if you switch this recipe back to NVIDIA-hosted inference.
NVIDIA_API_KEY=

# Telegram is resolved at runtime while the telegram channel wiring is baked at build time.
TELEGRAM_BOT_TOKEN=

# Writable NemoClaw state is persisted under `registry/recipes/nemoclaw/data/`.
# After the first launch, the dashboard token is exported to:
#   registry/recipes/nemoclaw/data/metadata/openclaw-token.txt