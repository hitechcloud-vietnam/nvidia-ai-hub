# Live VLM WebUI runtime configuration
# The container uses host networking so localhost points to services running on NVIDIA GPUs.
# Default backend: local Ollama vision endpoint on port 11434.

LIVE_VLM_API_BASE=http://localhost:11434/v1
LIVE_VLM_DEFAULT_MODEL=llama3.2-vision:11b
LIVE_VLM_PROCESS_EVERY=30
PORT=8090
