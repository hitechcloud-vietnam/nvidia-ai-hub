{
  "name": "nvidia-ai-hub-frontend",
  "private": true,
  "version": "0.0.0",
  "description": "Electron and web frontend for NVIDIA AI Hub by Pho Tue SoftWare Solutions JSC.",
  "author": "Pho Tue SoftWare And Technology Solutions Joint Stock Company",
  "license": "SEE LICENSE IN ../LICENSE",
  "homepage": "https://github.com/hitechcloud-vietnam/nvidia-ai-hub",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hitechcloud-vietnam/nvidia-ai-hub.git"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite build && vite",
    "build": "vite build",
    "build:web": "vite build",
    "build:backend": "node ./electron/scripts/build-backend.mjs",
    "build:icons": "node ./electron/scripts/generate-icons.mjs",
    "clean:release": "node ./electron/scripts/clean-release.mjs",
    "electron:ensure": "node ./electron/scripts/ensure-electron.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "desktop:dev": "npm run build:web && npm run build:icons && npm run electron:ensure && electron .",
    "desktop:pack": "npm run clean:release && npm run build:web && npm run build:icons && npm run build:backend && npm run electron:ensure && electron-builder --dir",
    "desktop:dist": "npm run clean:release && npm run build:web && npm run build:icons && npm run build:backend && npm run electron:ensure && electron-builder",
    "postinstall": "npm run electron:ensure"
  },
  "dependencies": {
    "i18next": "^26.0.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.4",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "electron": "^37.5.0",
    "electron-builder": "^26.0.12",
    "@electron/notarize": "^3.1.0",
    "globals": "^16.5.0",
    "icon-gen": "^3.0.1",
    "tailwindcss": "^4.2.0",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.photue.nvidia-ai-hub",
    "productName": "NVIDIA AI Hub",
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/backend-dist{,/**/*}",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/backend-dist",
        "to": "backend"
      },
      {
        "from": "../registry",
        "to": "app-bundle/registry"
      },
      {
        "from": "dist",
        "to": "app-bundle/frontend/dist"
      }
    ],
    "asar": true,
    "npmRebuild": false,
    "afterSign": "electron/notarize.cjs",
    "win": {
      "icon": "build-assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NVIDIA AI Hub"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": "${CSC_NAME}",
      "icon": "build-assets/icon.icns",
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Development",
      "icon": "public/logos/nvidia.png",
      "synopsis": "Desktop launcher for NVIDIA AI Hub",
      "description": "Desktop distribution that bundles the NVIDIA AI Hub frontend and a local FastAPI backend runtime."
    }
  }
}
